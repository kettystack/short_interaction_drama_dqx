DATABASE_URL=postgresql+asyncpg://sdi:sdi@localhost:5432/sdi
REDIS_URL=redis://localhost:6379/0

# Doubao / Volcengine Ark — 文本剧情续写优先读取 STORY_CHAT_*，
# 未配置时依次回退 ARK_* / AIGC_VIDEO_MULTIMODAL_* / DOUBAO_*。
ARK_API_KEY=
ARK_ENDPOINT=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
STORY_CHAT_API_KEY=
STORY_CHAT_ENDPOINT=
STORY_CHAT_BASE_URL=
STORY_CHAT_TIMEOUT_SECONDS=60
STORY_CHAT_MAX_TOKENS=900

# 旧文本模型配置，仍保留兼容
DOUBAO_API_KEY=
DOUBAO_ENDPOINT=

# Advanced feature switches
ADMIN_API_TOKEN=local-admin-token
AUTH_TOKEN_SECRET=local-dev-auth-secret
AUTH_ACCESS_TOKEN_TTL_MINUTES=1440
PUBLIC_BASE_URL=http://127.0.0.1:8000
AIGC_VIDEO_PROVIDER=seedance
AIGC_VIDEO_REAL_ENABLED=true
AIGC_VIDEO_FALLBACK_TO_ASSETS=false
AIGC_VIDEO_ENDPOINT_ID=
AIGC_VIDEO_MODEL=doubao-seedance-1-0-pro-fast-251015
AIGC_VIDEO_TASK_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks
AIGC_VIDEO_RESOLUTION=720p
AIGC_VIDEO_GENERATE_AUDIO=false
AIGC_VIDEO_WATERMARK=false
AIGC_VIDEO_SEED=-1
AIGC_VIDEO_QUALITY_MIN_SCORE=0.58
AIGC_VIDEO_REQUIRE_FIRST_FRAME=true
AIGC_VIDEO_MULTIMODAL_ENABLED=true
AIGC_VIDEO_MULTIMODAL_ENDPOINT=
AIGC_VIDEO_MULTIMODAL_API_KEY=
AIGC_VIDEO_AUTO_PUBLISH_MIN_SCORE=0.82
AIGC_VIDEO_REVIEW_MIN_SCORE=0.58
AIGC_VIDEO_TRANSCODE_ENABLED=true
AIGC_VIDEO_TARGET_WIDTH=720
AIGC_VIDEO_TARGET_HEIGHT=1280
AIGC_VIDEO_CAMERA_FIXED=false
AIGC_VIDEO_FIRST_FRAME_MIN_SSIM=0.72
AIGC_VIDEO_PROVIDER_MAX_DURATION_SECONDS=12
AIGC_INSERT_DURATION_SECONDS=12
AIGC_RESUME_OFFSET_SECONDS=5

# 个性化剧情分支视频
BRANCH_VIDEO_ENABLED=true
BRANCH_VIDEO_AUTO_PREWARM=true
BRANCH_VIDEO_PREWARM_SECONDS=60
BRANCH_VIDEO_TRIGGER_WINDOW_SECONDS=12
BRANCH_VIDEO_TARGET_DURATION_SECONDS=12
BRANCH_VIDEO_MAX_SESSIONS_PER_EPISODE=2
BRANCH_VIDEO_HIGHLIGHT_MIN_INTENSITY=0.78
# false: 分支视频必须来自独立 AIGC 任务，不回退到旧剧集剪辑
BRANCH_VIDEO_ALLOW_LEGACY_VARIANTS=false
AIGC_MEDIA_PUBLIC_BASE_URL=
GENERATED_MEDIA_ROOT=../data/generated
TEXT_MODERATION_BLOCK_WORDS=违法,辱骂,涉政敏感
RATE_LIMIT_ENABLED=true
STORY_CHAT_STORAGE=db

# 本地视频根目录
VIDEO_ROOT=../../juben/beipaixunbao
TIANXIADYI_VIDEO_ROOT=../../juben/tianxiadyi
SHIBASUITAINAINAI_VIDEO_ROOT=../../juben/shibasuitainainai
DATA_ROOT=../data
